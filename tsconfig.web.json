{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "composite": true,
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "outDir": "./out/renderer",
        "declaration": true,
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/renderer/*"
            ],
            "@shared/*": [
                "./src/shared/*"
            ]
        }
    },
    "include": [
        "src/renderer/**/*",
        "src/shared/**/*"
    ]
}